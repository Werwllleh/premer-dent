mixin otherDoctors()
    //- регистрация
    //- +regLibrary('lib-name/lib.css', 'lib-name/lib.js')
    //- +regComponent('component-name', true, true)

    //other-doctors
    .other-doctors&attributes(attributes)
        p.h2.other-doctors__title Другие врачи клиники
