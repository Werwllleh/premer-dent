            button.other-doctors__slider--button-prev
                +svg("arrow-left2")
            button.other-doctors__slider--button-next
                +svg("arrow-left2")
            .swiper
                .swiper-wrapper
                    .swiper-slide
                        +doctorCard("Стаж 21 год", "Авдошина Юлия Владимировна", "Зубной врач", "1")
